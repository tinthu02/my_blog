<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Danh sách đọc sau | Gmeow</title>
  <script>
    const theme = localStorage.getItem('theme');
    if (theme === 'dark') {
      document.documentElement.classList.add('dark-early');
      document.documentElement.setAttribute('data-bs-theme', 'dark');
    }
  </script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dark-mode.css">
  <style>
    /* ── Nav ── */
    .gmeow-nav {
      background: #f5ede0; border-bottom: 1.5px solid #e8d9c5;
      padding: 0; position: sticky; top: 0; z-index: 100;
    }
    .gmeow-nav .container {
      display: flex; align-items: center; justify-content: space-between;
      height: 64px; gap: 1rem;
    }
    .gmeow-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; }
    .gmeow-brand img { height: 50px; width: auto; }
    .gmeow-brand-text { font-size: 1.5rem; font-weight: 800; color: #2d2d2d; letter-spacing: -0.5px; }
    .gmeow-brand-text span { color: #c87941; }
    .gmeow-nav-right { display: flex; align-items: center; gap: 0.5rem; }
    .gmeow-links { display: flex; align-items: center; gap: 0.25rem; list-style: none; margin: 0; padding: 0; }
    .gmeow-links a {
      color: #2d2d2d; text-decoration: none; font-size: 1rem; font-weight: 600;
      padding: 6px 16px; border-radius: 20px; transition: background 0.15s, color 0.15s;
    }
    .gmeow-links a:hover { background: #ead6bc; }
    .gmeow-dark-btn {
      background: none; border: 1.5px solid #d4b896; border-radius: 50%;
      width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: background 0.15s; padding: 0; flex-shrink: 0;
    }
    .gmeow-dark-btn:hover { background: #ead6bc; border-color: #c87941; }
    [data-bs-theme="dark"] .gmeow-nav { background: #1e1a16; border-bottom-color: #3a3028; }
    [data-bs-theme="dark"] .gmeow-brand-text { color: #f0e6d8; }
    [data-bs-theme="dark"] .gmeow-links a { color: #b8a898; }
    [data-bs-theme="dark"] .gmeow-links a:hover { background: #2e2620; color: #f0e6d8; }
    [data-bs-theme="dark"] .gmeow-dark-btn { border-color: #4a3e32; }

    /* ── Page header ── */
    .rl-header {
      padding: 2.5rem 0 1.5rem;
      border-bottom: 1px solid #e8d9c5;
      margin-bottom: 2rem;
    }
    .rl-header h1 {
      font-size: 1.75rem; font-weight: 800;
      display: flex; align-items: center; gap: 10px;
    }
    .rl-count-badge {
      background: #c87941; color: #fff;
      font-size: 0.8rem; font-weight: 700;
      padding: 2px 10px; border-radius: 20px;
      vertical-align: middle;
    }

    /* ── Card ── */
    .rl-card {
      display: flex; gap: 16px;
      border: 1px solid #e8d9c5;
      border-radius: 12px;
      padding: 16px;
      background: #fff;
      transition: box-shadow 0.2s, transform 0.15s;
      position: relative;
    }
    .rl-card:hover { box-shadow: 0 6px 20px rgba(200,121,65,0.1); transform: translateY(-2px); }
    .rl-thumbnail {
      width: 100px; height: 70px;
      border-radius: 8px; object-fit: cover; flex-shrink: 0;
    }
    .rl-thumbnail-placeholder {
      width: 100px; height: 70px;
      border-radius: 8px; background: #f5ede0;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; color: #d4b896; flex-shrink: 0;
    }
    .rl-card-body { flex: 1; min-width: 0; }
    .rl-category {
      font-size: 0.68rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.8px;
      color: #c87941; margin-bottom: 4px;
    }
    .rl-title {
      font-size: 1rem; font-weight: 700; color: #2d2d2d;
      text-decoration: none; line-height: 1.4;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .rl-title:hover { color: #c87941; }
    .rl-excerpt {
      font-size: 0.82rem; color: #7a6a5a; margin: 4px 0 0;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .rl-meta { font-size: 0.75rem; color: #b0a090; margin-top: 6px; display: flex; gap: 10px; flex-wrap: wrap; }
    .rl-saved { font-size: 0.72rem; color: #c8a87a; }
    .rl-remove-btn {
      position: absolute; top: 12px; right: 12px;
      background: none; border: none; padding: 4px;
      color: #c0b0a0; cursor: pointer; border-radius: 6px;
      transition: color 0.15s, background 0.15s;
    }
    .rl-remove-btn:hover { color: #c0392b; background: #fff0ee; }

    /* Empty state */
    .rl-empty {
      text-align: center; padding: 4rem 0;
      color: #9a8a7a;
    }
    .rl-empty-icon { font-size: 3.5rem; margin-bottom: 1rem; }
    .rl-empty p { font-size: 1rem; margin-bottom: 1.5rem; }

    /* Clear all button */
    .btn-clear-all {
      font-size: 0.82rem; color: #c0392b;
      background: none; border: 1px solid #f5c6c6;
      border-radius: 20px; padding: 4px 14px; cursor: pointer;
      transition: all 0.15s;
    }
    .btn-clear-all:hover { background: #fff0ee; border-color: #c0392b; }

    /* Dark mode */
    [data-bs-theme="dark"] .rl-header { border-bottom-color: #3a3028; }
    [data-bs-theme="dark"] .rl-card { border-color: #3a3028; background: #1a1612; }
    [data-bs-theme="dark"] .rl-title { color: #f0e6d8; }
    [data-bs-theme="dark"] .rl-thumbnail-placeholder { background: #2a2018; color: #6a5a4a; }
    [data-bs-theme="dark"] .rl-excerpt { color: #8a7a6a; }
    [data-bs-theme="dark"] .rl-remove-btn { color: #6a5a4a; }
    [data-bs-theme="dark"] .rl-remove-btn:hover { color: #e74c3c; background: #2a1812; }
  </style>
</head>
<body>
  <nav class="gmeow-nav">
    <div class="container">
      <a class="gmeow-brand" href="/">
        <img src="/images/logo.png" alt="Gmeow" onerror="this.style.display='none'">
        <span class="gmeow-brand-text">G<span>meow</span></span>
      </a>
      <div class="gmeow-nav-right">
        <ul class="gmeow-links">
          <li><a href="/">Trang chủ</a></li>
        </ul>
        <button id="dark-mode-toggle" class="gmeow-dark-btn" aria-label="Chuyển dark mode">
          <img id="dark-mode-icon" src="/images/idea.png" width="18" height="18" alt="Dark mode">
        </button>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="rl-header">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <h1>
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#c87941" viewBox="0 0 16 16">
            <path d="M2 2v13.5a.5.5 0 0 0 .777.416L8 13.101l5.223 2.815A.5.5 0 0 0 14 15.5V2a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>
          </svg>
          Danh sách đọc sau
          <span class="rl-count-badge" id="rl-count" style="display:none">0</span>
        </h1>
        <button class="btn-clear-all" id="clear-all-btn" style="display:none" onclick="clearAll()">
          Xóa tất cả
        </button>
      </div>
    </div>

    <!-- Danh sách -->
    <div id="rl-list" class="d-flex flex-column gap-3 pb-5"></div>

    <!-- Empty state -->
    <div id="rl-empty" class="rl-empty" style="display:none">
      <div class="rl-empty-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="#d4b896" viewBox="0 0 16 16">
          <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>
        </svg>
      </div>
      <p>Bạn chưa lưu bài nào.</p>
      <a href="/" class="btn" style="background:#c87941;color:#fff;border-radius:20px;padding:8px 24px;font-weight:600;">
        Khám phá bài viết
      </a>
    </div>
  </div>

  <%- include('partials/back-to-top') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/dark-mode.js"></script>
  <script>
    function getBookmarks() {
      try { return JSON.parse(localStorage.getItem('gmeow_bookmarks') || '[]'); }
      catch { return []; }
    }

    function saveBookmarks(list) {
      localStorage.setItem('gmeow_bookmarks', JSON.stringify(list));
    }

    function removeBookmark(id) {
      const bookmarks = getBookmarks().filter(b => b.id !== id);
      saveBookmarks(bookmarks);
      renderList();
    }

    function clearAll() {
      if (!confirm('Xóa toàn bộ danh sách đọc sau?')) return;
      localStorage.removeItem('gmeow_bookmarks');
      renderList();
    }

    function timeAgo(dateStr) {
      const diff = Date.now() - new Date(dateStr).getTime();
      const m = Math.floor(diff / 60000);
      const h = Math.floor(m / 60);
      const d = Math.floor(h / 24);
      if (d > 0) return `${d} ngày trước`;
      if (h > 0) return `${h} giờ trước`;
      if (m > 0) return `${m} phút trước`;
      return 'Vừa lưu';
    }

    function renderList() {
      const bookmarks = getBookmarks();
      const list = document.getElementById('rl-list');
      const empty = document.getElementById('rl-empty');
      const countBadge = document.getElementById('rl-count');
      const clearBtn = document.getElementById('clear-all-btn');

      if (bookmarks.length === 0) {
        list.innerHTML = '';
        empty.style.display = 'block';
        countBadge.style.display = 'none';
        clearBtn.style.display = 'none';
        return;
      }

      empty.style.display = 'none';
      countBadge.style.display = 'inline';
      countBadge.textContent = bookmarks.length;
      clearBtn.style.display = 'inline';

      list.innerHTML = bookmarks.map(b => `
        <div class="rl-card" id="rl-item-${b.id}">
          ${b.thumbnail
            ? `<img src="${b.thumbnail}" alt="${escHtml(b.title)}" class="rl-thumbnail" loading="lazy">`
            : `<div class="rl-thumbnail-placeholder">✦</div>`
          }
          <div class="rl-card-body">
            <div class="rl-category">${escHtml(b.category)}</div>
            <a href="${b.url}" class="rl-title">${escHtml(b.title)}</a>
            ${b.excerpt ? `<p class="rl-excerpt">${escHtml(b.excerpt)}</p>` : ''}
            <div class="rl-meta">
              <span>${b.readingTime || 1} phút đọc</span>
              <span class="rl-saved">Lưu ${timeAgo(b.savedAt)}</span>
            </div>
          </div>
          <button class="rl-remove-btn" onclick="removeBookmark('${b.id}')" title="Bỏ khỏi danh sách">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
            </svg>
          </button>
        </div>
      `).join('');
    }

    function escHtml(str) {
      if (!str) return '';
      return String(str).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]));
    }

    renderList();
  </script>
</body>
</html>
