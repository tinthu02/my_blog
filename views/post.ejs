  <!-- ═══════════════════════════════════════
       SCRIPT: Copy code block
  ════════════════════════════════════════ -->
  <script>
    document.querySelectorAll('#post-content pre').forEach(pre => {
      const wrapper = document.createElement('div');
      wrapper.style.cssText = 'position:relative;';
      pre.parentNode.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement('button');
      btn.textContent = 'Copy';
      btn.style.cssText = `
        position: absolute; top: 8px; right: 8px;
        padding: 3px 10px; font-size: 0.75rem;
        border: 1px solid #94a3b8; border-radius: 5px;
        background: rgba(30,41,59,0.85); color: #f1f5f9;
        cursor: pointer; transition: opacity 0.2s, background 0.2s;
        backdrop-filter: blur(4px);
      `;
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code') ? pre.querySelector('code').innerText : pre.innerText;
        try {
          await navigator.clipboard.writeText(code);
          btn.textContent = '✓ Đã copy';
          btn.style.borderColor = '#4ade80';
          btn.style.color = '#4ade80';
          setTimeout(() => { btn.textContent = 'Copy'; btn.style.borderColor = '#94a3b8'; btn.style.color = '#e2e8f0'; }, 2000);
        } catch {
          btn.textContent = 'Lỗi!';
          setTimeout(() => btn.textContent = 'Copy', 2000);
        }
      });
      wrapper.appendChild(btn);
    });
  </script>

  <!-- ═══════════════════════════════════════
       SCRIPT: Upvote
  ════════════════════════════════════════ -->
  <script>
    const postId = '<%= post._id %>';
    const upvoteKey = 'upvoted_' + postId;
    const upvoteBtn = document.getElementById('upvote-btn');
    const upvoteArrow = document.getElementById('upvote-arrow');
    const upvoteCount = document.getElementById('upvote-count');

    if (localStorage.getItem(upvoteKey)) {
      upvoteBtn.classList.remove('btn-outline-warning');
      upvoteBtn.classList.add('btn-warning');
      upvoteBtn.disabled = true;
    }

    async function handleUpvote() {
      if (localStorage.getItem(upvoteKey)) return;
      try {
        const res = await fetch(`/post/${postId}/like`, { method: 'POST' });
        const data = await res.json();
        if (data.likes !== undefined) {
          upvoteCount.textContent = data.likes;
          localStorage.setItem(upvoteKey, '1');
          upvoteBtn.classList.remove('btn-outline-warning');
          upvoteBtn.classList.add('btn-warning');
          upvoteBtn.disabled = true;
        }
      } catch (err) {
        console.error('Lỗi upvote:', err);
      }
    }
  </script>

<!-- ═══════════════════════════════════════
       SCRIPT: Bookmark data
  ════════════════════════════════════════ -->
  <script id="bookmark-data" type="application/json">
    <%- JSON.stringify({
      id: String(post._id),
      title: post.title || '',
      excerpt: (post.excerpt || '').substring(0, 120),
      category: post.category || '',
      readingTime: post.readingTime || 1,
      thumbnail: post.thumbnail || '',
      url: '/post/' + String(post._id)
    }) %>
  </script>
  <script>
    var bookmarkData = JSON.parse(document.getElementById('bookmark-data').textContent);
  </script>

  <!-- ═══════════════════════════════════════
       SCRIPT: Comment + Reply (AJAX)
  ════════════════════════════════════════ -->
  <script>
    // ── Tiện ích ──────────────────────────────────────────
    function escapeHtml(text) {
      const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
      return String(text).replace(/[&<>"']/g, m => map[m]);
    }

    function getCommentCount() {
      const el = document.getElementById('comment-count');
      return el ? parseInt(el.textContent) || 0 : 0;
    }

    function setCommentCount(n) {
      const el = document.getElementById('comment-count');
      if (el) el.textContent = n;
    }

    // ── Bookmark (Reading list) — đọc data từ HTML attribute, không dùng EJS trong JS ──
    function getBookmarks() {
      try { return JSON.parse(localStorage.getItem('gmeow_bookmarks') || '[]'); }
      catch { return []; }
    }

    function isBookmarked(id) {
      return getBookmarks().some(function(b) { return b.id === id; });
    }

    function updateBookmarkUI() {
      var btn = document.getElementById('bookmark-btn');
      var label = document.getElementById('bookmark-label');
      var icon = document.getElementById('bookmark-icon');
      if (!btn) return;
      var id = btn.dataset.id;
      if (isBookmarked(id)) {
        btn.classList.add('bookmarked');
        label.textContent = 'Đã lưu';
        icon.innerHTML = '<path d="M2 2v13.5a.5.5 0 0 0 .777.416L8 13.101l5.223 2.815A.5.5 0 0 0 14 15.5V2a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>';
      } else {
        btn.classList.remove('bookmarked');
        label.textContent = 'Đọc sau';
        icon.innerHTML = '<path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>';
      }
      updateNavBadge();
    }

    function updateNavBadge() {
      var count = getBookmarks().length;
      var badge = document.getElementById('nav-rl-count');
      if (!badge) return;
      if (count > 0) {
        badge.style.display = 'inline-flex';
        badge.textContent = count > 9 ? '9+' : count;
      } else {
        badge.style.display = 'none';
      }
    }

    function toggleBookmark() {
      var btn = document.getElementById('bookmark-btn');
      if (!btn) return;
      var id = btn.dataset.id;
      var bookmarks = getBookmarks();
      if (isBookmarked(id)) {
        bookmarks = bookmarks.filter(function(b) { return b.id !== id; });
      } else {
        bookmarks.unshift({
          id: bookmarkData.id,
          title: bookmarkData.title,
          excerpt: bookmarkData.excerpt,
          category: bookmarkData.category,
          readingTime: bookmarkData.readingTime,
          thumbnail: bookmarkData.thumbnail,
          url: bookmarkData.url,
          savedAt: new Date().toISOString()
        });
      }
      localStorage.setItem('gmeow_bookmarks', JSON.stringify(bookmarks));
      updateBookmarkUI();
    }

    document.addEventListener('DOMContentLoaded', updateBookmarkUI);

    // ── Toggle form reply ──────────────────────────────────
    function toggleReplyForm(commentId) {
      const form = document.getElementById(`reply-form-${commentId}`);
      const btn  = document.querySelector(`#comment-${commentId} > .card-body > .d-flex .reply-btn`);
      if (!form) return;
      const isOpen = form.classList.toggle('show');
      if (btn) btn.classList.toggle('active', isOpen);
      if (isOpen) {
        const input = document.getElementById(`reply-author-${commentId}`);
        if (input) input.focus();
      }
    }

    // ── Gửi reply ─────────────────────────────────────────
    async function submitReply(commentId) {
      const authorInput  = document.getElementById(`reply-author-${commentId}`);
      const contentInput = document.getElementById(`reply-content-${commentId}`);
      const errorDiv     = document.getElementById(`reply-error-${commentId}`);

      const author  = authorInput.value.trim();
      const content = contentInput.value.trim();

      // Ẩn lỗi cũ
      errorDiv.classList.add('d-none');

      if (!author)  return showReplyError(commentId, 'Vui lòng nhập tên của bạn');
      if (!content) return showReplyError(commentId, 'Vui lòng nhập nội dung trả lời');

      // Lấy nút gửi và disable
      const submitBtn = document.querySelector(`#reply-form-${commentId} .btn-primary`);
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Đang gửi...'; }

      try {
        const res = await fetch(`/api/posts/${postId}/comments/${commentId}/reply`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ author, content })
        });
        const data = await res.json();

        if (!res.ok || !data.success) throw new Error(data.message || 'Lỗi không xác định');

        // Thêm reply vào DOM
        appendReplyToDOM(commentId, data.comment);

        // Reset form & đóng
        authorInput.value  = '';
        contentInput.value = '';
        toggleReplyForm(commentId);

        // Tăng đếm
        setCommentCount(getCommentCount() + 1);

      } catch (err) {
        showReplyError(commentId, err.message);
      } finally {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Gửi trả lời'; }
      }
    }

    function showReplyError(commentId, message) {
      const el = document.getElementById(`reply-error-${commentId}`);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('d-none');
      setTimeout(() => el.classList.add('d-none'), 5000);
    }

    function appendReplyToDOM(parentCommentId, reply) {
      let container = document.getElementById(`replies-${parentCommentId}`);
      if (!container) {
        container = document.createElement('div');
        container.className = 'replies-container';
        container.id = `replies-${parentCommentId}`;
        // Chèn trước reply-form-wrapper
        const form = document.getElementById(`reply-form-${parentCommentId}`);
        if (form) form.parentNode.insertBefore(container, form);
      }
      container.style.display = ''; // bỏ display:none nếu có

      const date = new Date(reply.createdAt);
      const formattedDate = date.toLocaleString('vi-VN');

      const div = document.createElement('div');
      div.className = 'reply-item';
      div.id = `comment-${reply._id}`;
      div.innerHTML = `
        <div class="d-flex justify-content-between align-items-start mb-1">
          <div>
            <span class="reply-author-badge"><img src="/images/group.png" width="13" height="13" alt="reply" style="vertical-align:middle; margin-top:-2px; margin-right:2px;">Trả lời</span>
            <span class="comment-author">${escapeHtml(reply.author)}</span>
            <span class="comment-time ms-2">
              <time datetime="${date.toISOString()}">${formattedDate}</time>
            </span>
          </div>
          <button class="reply-btn" onclick="toggleReplyForm('${parentCommentId}')"><img src="/images/reply-message.png" width="14" height="14" alt="trả lời" style="vertical-align:middle; margin-top:-2px; margin-right:3px;">Trả lời</button>
        </div>
        <p class="mb-0">${escapeHtml(reply.content)}</p>
      `;
      container.appendChild(div);

      // Scroll mượt đến reply vừa gửi
      setTimeout(() => div.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 100);
    }

    // ── Gửi bình luận gốc ─────────────────────────────────
    document.addEventListener('DOMContentLoaded', function() {
      const commentForm  = document.getElementById('comment-form');
      const commentsList = document.getElementById('comments-list');
      const commentError = document.getElementById('comment-error');
      const submitBtn    = document.getElementById('submit-btn');
      const authorInput  = document.getElementById('author');
      const contentInput = document.getElementById('content');

      commentForm.addEventListener('submit', async function(e) {
        e.preventDefault();

        const author  = authorInput.value.trim();
        const content = contentInput.value.trim();

        commentError.classList.add('d-none');

        if (!author)  return showError('Vui lòng nhập tên của bạn');
        if (!content) return showError('Vui lòng nhập nội dung bình luận');

        submitBtn.disabled    = true;
        submitBtn.textContent = 'Đang gửi...';

        try {
          const res = await fetch(`/api/posts/${postId}/comments`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ author, content })
          });
          const data = await res.json();
          if (!res.ok || !data.success) throw new Error(data.message || 'Lỗi không xác định');

          // Thêm comment mới vào đầu danh sách
          addRootCommentToDOM(data.comment);

          authorInput.value  = '';
          contentInput.value = '';

          setCommentCount(getCommentCount() + 1);

          const noComments = document.getElementById('no-comments');
          if (noComments) noComments.remove();

        } catch (error) {
          showError(error.message);
        } finally {
          submitBtn.disabled    = false;
          submitBtn.textContent = 'Gửi bình luận';
        }
      });

      function addRootCommentToDOM(comment) {
        const date = new Date(comment.createdAt);
        const formattedDate = date.toLocaleString('vi-VN');
        const cid = comment._id;

        const div = document.createElement('div');
        div.className = 'comment-item';
        div.id = `comment-${cid}`;
        div.innerHTML = `
          <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <div>
                <span class="comment-author"><img src="/images/user.png" width="16" height="16" alt="user" style="vertical-align:middle; margin-top:-2px; margin-right:4px;">${escapeHtml(comment.author)}</span>
                <span class="comment-time ms-2">
                  <time datetime="${date.toISOString()}">${formattedDate}</time>
                </span>
              </div>
              <button class="reply-btn" onclick="toggleReplyForm('${cid}')"><img src="/images/reply-message.png" width="14" height="14" alt="trả lời" style="vertical-align:middle; margin-top:-2px; margin-right:3px;">Trả lời</button>
            </div>
            <p class="mb-2 mt-1">${escapeHtml(comment.content)}</p>
            <div class="replies-container" id="replies-${cid}" style="display:none;"></div>
            <div class="reply-form-wrapper" id="reply-form-${cid}">
              <p class="mb-2 small text-muted">Trả lời <strong>${escapeHtml(comment.author)}</strong>:</p>
              <div class="mb-2">
                <input type="text" class="form-control form-control-sm"
                       placeholder="Tên của bạn"
                       id="reply-author-${cid}" maxlength="50">
              </div>
              <div class="mb-2">
                <textarea class="form-control form-control-sm"
                          placeholder="Nội dung trả lời..."
                          id="reply-content-${cid}" rows="2" maxlength="1000"></textarea>
              </div>
              <div class="d-flex gap-2">
                <button class="btn btn-primary btn-sm" onclick="submitReply('${cid}')">Gửi trả lời</button>
                <button class="btn btn-outline-secondary btn-sm" onclick="toggleReplyForm('${cid}')">Hủy</button>
              </div>
              <div class="alert alert-danger mt-2 d-none small" id="reply-error-${cid}"></div>
            </div>
          </div>
        `;
        // Chèn lên đầu danh sách (mới nhất lên đầu)
        commentsList.insertBefore(div, commentsList.firstChild);
        setTimeout(() => div.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 100);
      }

      function showError(message) {
        commentError.textContent = message;
        commentError.classList.remove('d-none');
        setTimeout(() => commentError.classList.add('d-none'), 5000);
      }
    });
  </script>
</body>
</html>
