<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <!-- Sửa href thành /admin/posts -->
      <a class="navbar-brand" href="/admin/posts">Admin Panel</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/posts/new">+ Bài viết mới</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/logout">Đăng xuất</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h2>Quản lý bài viết</h2>
    <hr>
    <% if (posts && posts.length > 0) { %>
      <table class="table table-bordered table-striped">
        <thead>
          <tr>
            <th>Tiêu đề</th>
            <th>Danh mục</th>
            <th>Ngày tạo</th>
            <th>Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% posts.forEach(post => { %>
            <tr>
              <td><%= post.title %></td>
              <td><%= post.category %></td>
              <td><%= post.createdAt.toLocaleDateString('vi-VN') %></td>
              <td>
                <a href="/admin/posts/<%= post._id %>/edit" class="btn btn-sm btn-warning">Sửa</a>
                <form action="/admin/posts/<%= post._id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa?')">Xóa</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <!-- Sửa href thành /admin/posts/new -->
      <p>Chưa có bài viết nào. <a href="/admin/posts/new">Tạo bài viết đầu tiên</a></p>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>