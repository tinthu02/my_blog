<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f8fafc; }

    .stat-card {
      border-radius: 12px;
      border: none;
      padding: 20px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }
    .stat-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }
    .stat-label { font-size: 0.8rem; color: #64748b; margin-bottom: 2px; }
    .stat-value { font-size: 1.6rem; font-weight: 700; line-height: 1; }

    .nav-tabs .nav-link { color: #64748b; font-weight: 500; }
    .nav-tabs .nav-link.active { color: #0f172a; font-weight: 600; }

    .table th { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.04em; color: #64748b; }

    .status-badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .status-published { background: #dcfce7; color: #16a34a; }
    .status-draft     { background: #fef9c3; color: #ca8a04; }

    .top-bar {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 20px; flex-wrap: wrap; gap: 10px;
    }

    .comment-row td { vertical-align: middle; font-size: 0.88rem; }
    .comment-content-cell { max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid px-4">
      <a class="navbar-brand fw-bold" href="/admin/posts">⚙️ Admin Panel</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto gap-1">
          <li class="nav-item"><a class="nav-link" href="/" target="_blank">🌐 Trang chủ</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/posts/new">✏️ Bài viết mới</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/profile">👤 Profile</a></li>
          <li class="nav-item"><a class="nav-link text-danger" href="/admin/logout">Đăng xuất</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid px-4 py-4">

    <!-- ── Thẻ thống kê tổng quan ── -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="stat-card bg-white">
          <div class="stat-icon" style="background:#dbeafe;">📄</div>
          <div>
            <div class="stat-label">Bài đã đăng</div>
            <div class="stat-value text-primary"><%= stats.totalPosts %></div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card bg-white">
          <div class="stat-icon" style="background:#fef9c3;">📝</div>
          <div>
            <div class="stat-label">Bài nháp</div>
            <div class="stat-value text-warning"><%= stats.totalDrafts %></div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card bg-white">
          <div class="stat-icon" style="background:#dcfce7;">💬</div>
          <div>
            <div class="stat-label">Bình luận</div>
            <div class="stat-value text-success"><%= stats.totalComments %></div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card bg-white">
          <div class="stat-icon" style="background:#fce7f3;">👁️</div>
          <div>
            <div class="stat-label">Tổng lượt xem</div>
            <div class="stat-value text-danger"><%= stats.totalViews.toLocaleString('vi-VN') %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Tabs ── -->
    <ul class="nav nav-tabs mb-4" id="adminTabs">
      <li class="nav-item">
        <a class="nav-link <%= tab === 'stats' ? 'active' : '' %>" href="/admin/posts?tab=stats">
          📊 Thống kê
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= tab === 'posts' || tab === undefined ? 'active' : '' %>" href="/admin/posts?tab=posts">
          📄 Bài viết
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= tab === 'comments' ? 'active' : '' %>" href="/admin/posts?tab=comments">
          💬 Bình luận
          <% if (stats.totalComments > 0) { %>
            <span class="badge bg-secondary ms-1"><%= stats.totalComments %></span>
          <% } %>
        </a>
      </li>
    </ul>

    <!-- ══════════════════════════════════════
         TAB: THỐNG KÊ
    ══════════════════════════════════════ -->
    <% if (tab === 'stats') { %>
    <div class="row g-4">

      <!-- Top bài nhiều view -->
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold border-bottom">
            👁️ Top 5 bài nhiều lượt xem nhất
          </div>
          <div class="card-body p-0">
            <% if (topByViews.length > 0) { %>
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3">#</th>
                  <th>Tiêu đề</th>
                  <th class="text-end pe-3">Lượt xem</th>
                </tr>
              </thead>
              <tbody>
                <% topByViews.forEach((post, i) => { %>
                <tr>
                  <td class="ps-3 text-muted"><%= i + 1 %></td>
                  <td>
                    <a href="/post/<%= post._id %>" target="_blank" class="text-decoration-none text-dark fw-medium">
                      <%= post.title %>
                    </a>
                    <br><small class="text-muted"><%= post.category %></small>
                  </td>
                  <td class="text-end pe-3 fw-bold text-primary"><%= (post.views || 0).toLocaleString('vi-VN') %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
              <p class="text-muted p-3 mb-0">Chưa có dữ liệu.</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Top bài nhiều bình luận -->
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold border-bottom">
            💬 Top 5 bài nhiều bình luận nhất
          </div>
          <div class="card-body p-0">
            <% if (topByComments.length > 0) { %>
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3">#</th>
                  <th>Tiêu đề</th>
                  <th class="text-end pe-3">Bình luận</th>
                </tr>
              </thead>
              <tbody>
                <% topByComments.forEach((item, i) => { %>
                <tr>
                  <td class="ps-3 text-muted"><%= i + 1 %></td>
                  <td>
                    <a href="/post/<%= item.postId %>" target="_blank" class="text-decoration-none text-dark fw-medium">
                      <%= item.title %>
                    </a>
                  </td>
                  <td class="text-end pe-3 fw-bold text-success"><%= item.commentCount %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
            <% } else { %>
              <p class="text-muted p-3 mb-0">Chưa có bình luận nào.</p>
            <% } %>
          </div>
        </div>
      </div>

    </div>
    <% } %>

    <!-- ══════════════════════════════════════
         TAB: BÀI VIẾT
    ══════════════════════════════════════ -->
    <% if (tab === 'posts') { %>
    <div class="top-bar">
      <span class="text-muted small">Tổng: <strong><%= posts.length %></strong> bài</span>
      <a href="/admin/posts/new" class="btn btn-primary btn-sm">✏️ Bài viết mới</a>
    </div>

    <% if (posts && posts.length > 0) { %>
    <div class="card border-0 shadow-sm">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3">Tiêu đề</th>
            <th>Danh mục</th>
            <th>Ngày tạo</th>
            <th>Lượt xem</th>
            <th>Trạng thái</th>
            <th class="text-end pe-3">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% posts.forEach(post => { %>
          <tr>
            <td class="ps-3 fw-medium">
              <a href="/post/<%= post._id %>" target="_blank" class="text-decoration-none text-dark">
                <%= post.title %>
              </a>
            </td>
            <td><span class="badge bg-light text-secondary border"><%= post.category %></span></td>
            <td class="text-muted small"><%= post.createdAt.toLocaleDateString('vi-VN') %></td>
            <td class="text-muted small"><%= (post.views || 0).toLocaleString('vi-VN') %></td>
            <td>
              <span class="status-badge <%= post.status === 'draft' ? 'status-draft' : 'status-published' %>">
                <%= post.status === 'draft' ? '📝 Nháp' : '✅ Đã đăng' %>
              </span>
            </td>
            <td class="text-end pe-3">
              <div class="d-flex gap-1 justify-content-end">
                <!-- Nút đổi trạng thái nhanh -->
                <form action="/admin/posts/<%= post._id %>/status?_method=PATCH" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm <%= post.status === 'draft' ? 'btn-outline-success' : 'btn-outline-warning' %>"
                          title="<%= post.status === 'draft' ? 'Đăng bài' : 'Chuyển về nháp' %>">
                    <%= post.status === 'draft' ? '▶ Đăng' : '⏸ Nháp' %>
                  </button>
                </form>
                <a href="/admin/posts/<%= post._id %>/edit" class="btn btn-sm btn-outline-primary">Sửa</a>
                <form action="/admin/posts/<%= post._id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-outline-danger"
                          onclick="return confirm('Xóa bài \'<%= post.title.replace(/'/g, '') %>\'?')">Xóa</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <p class="text-muted">Chưa có bài viết nào. <a href="/admin/posts/new">Tạo bài đầu tiên</a></p>
    <% } %>
    <% } %>

    <!-- ══════════════════════════════════════
         TAB: BÌNH LUẬN
    ══════════════════════════════════════ -->
    <% if (tab === 'comments') { %>
    <div class="top-bar">
      <span class="text-muted small">Tổng: <strong><%= recentComments.length %></strong> bình luận gần nhất</span>
    </div>

    <% if (recentComments.length > 0) { %>
    <div class="card border-0 shadow-sm">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3">Tên</th>
            <th>Nội dung</th>
            <th>Bài viết</th>
            <th>Loại</th>
            <th>Thời gian</th>
            <th class="text-end pe-3">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% recentComments.forEach(comment => { %>
          <tr class="comment-row">
            <td class="ps-3 fw-medium"><%= comment.author %></td>
            <td class="comment-content-cell" title="<%= comment.content %>"><%= comment.content %></td>
            <td>
              <a href="/post/<%= comment.postId %>" target="_blank" class="text-decoration-none small text-primary">
                <%= comment.postTitle %>
              </a>
            </td>
            <td>
              <% if (comment.parentId) { %>
                <span class="badge bg-light text-secondary border">↩ Reply</span>
              <% } else { %>
                <span class="badge bg-light text-secondary border">💬 Gốc</span>
              <% } %>
            </td>
            <td class="text-muted small"><%= comment.createdAt.toLocaleString('vi-VN') %></td>
            <td class="text-end pe-3">
              <form action="/admin/comments/<%= comment._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('Xóa bình luận này?')">Xóa</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <p class="text-muted">Chưa có bình luận nào.</p>
    <% } %>
    <% } %>

  </div><!-- /.container-fluid -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
