<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog - Trang chủ</title>
  <meta name="description" content="Blog cá nhân — nơi chia sẻ bài viết về công nghệ, đời sống, du lịch, ẩm thực và nhiều chủ đề thú vị khác.">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= process.env.SITE_URL || 'http://localhost:3000' %>/">
  <meta property="og:title" content="Blog - Trang chủ">
  <meta property="og:description" content="Blog cá nhân — nơi chia sẻ bài viết về công nghệ, đời sống, du lịch, ẩm thực và nhiều chủ đề thú vị khác.">
  <meta property="og:image" content="<%= process.env.SITE_URL || 'http://localhost:3000' %>/images/og-default.png">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Blog - Trang chủ">
  <meta name="twitter:description" content="Blog cá nhân — nơi chia sẻ bài viết về công nghệ, đời sống, du lịch, ẩm thực và nhiều chủ đề thú vị khác.">
  <meta name="twitter:image" content="<%= process.env.SITE_URL || 'http://localhost:3000' %>/images/og-default.png">
  <!-- Anti-flash: phải đứng trước mọi CSS -->
  <script>
    if (localStorage.getItem('theme') === 'dark') {
      document.documentElement.classList.add('dark-early');
    }
  </script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dark-mode.css">
</head>
<body>
  <style>
    /* ── Gmeow Header ── */
    .gmeow-nav {
      background: #f5ede0;
      border-bottom: 1.5px solid #e8d9c5;
      padding: 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .gmeow-nav .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      gap: 1rem;
    }
    .gmeow-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      flex-shrink: 0;
    }
    .gmeow-brand img { height: 50px; width: auto; }
    .gmeow-brand-text {
      font-size: 1.5rem;
      font-weight: 800;
      color: #2d2d2d;
      letter-spacing: -0.5px;
    }
    .gmeow-brand-text span { color: #c87941; }
    .gmeow-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .gmeow-links a {
      color: #2d2d2d;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 600;
      padding: 6px 16px;
      border-radius: 20px;
      transition: background 0.15s, color 0.15s;
    }
    .gmeow-links a:hover { background: #ead6bc; color: #2d2d2d; }
    .gmeow-dark-btn {
      background: none;
      border: 1.5px solid #d4b896;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
      padding: 0;
      flex-shrink: 0;
    }
    .gmeow-dark-btn:hover { background: #ead6bc; border-color: #c87941; }
    .gmeow-nav-right { display: flex; align-items: center; gap: 0.5rem; }
    .gmeow-rl-btn {
      display: inline-flex; align-items: center; gap: 6px;
      color: #2d2d2d; text-decoration: none; font-size: 0.88rem; font-weight: 600;
      padding: 6px 14px; border-radius: 20px;
      border: 1.5px solid #d4b896;
      transition: background 0.15s, border-color 0.15s;
      position: relative;
    }
    .gmeow-rl-btn:hover { background: #ead6bc; border-color: #c87941; color: #2d2d2d; }
    .gmeow-rl-count {
      background: #c87941; color: #fff;
      font-size: 0.65rem; font-weight: 700;
      width: 16px; height: 16px; border-radius: 50%;
      display: inline-flex; align-items: center; justify-content: center;
    }
    /* dark mode styles handled by dark-mode.css via body.dark */
    .card-author {
      font-size: 0.78rem;
      color: #9a8a7a;
      display: flex;
      align-items: center;
      gap: 4px;
      margin: 0;
    }
    .card-author-link {
      color: #c87941;
      text-decoration: none;
      font-weight: 500;
    }
    .card-author-link:hover {
      color: #a8622e;
      text-decoration: underline;
    }
    /* Dark mode for hero and category section */
    [data-bs-theme="dark"] h1 { color: #f0e6d8 !important; }
    [data-bs-theme="dark"] .container > div:first-child { border-bottom-color: #3a3028 !important; }
    [data-bs-theme="dark"] .form-control,
    [data-bs-theme="dark"] .form-select {
      border-color: #4a3e32 !important;
      background: #1e1a16 !important;
      color: #f0e6d8 !important;
    }
    [data-bs-theme="dark"] .btn-primary {
      background: #c87941 !important;
      border-color: #c87941 !important;
    }    /* ── Gmeow Footer ── */
    .gmeow-footer {
      background: #f5ede0;
      color: #2d2d2d;
      padding: 3rem 0 1.5rem;
      margin-top: 4rem;
    }
    .gmeow-footer-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 0.75rem;
    }
    .gmeow-footer-brand img {
      height: 44px;
      width: auto;
    }
    .gmeow-footer-brand-name {
      font-size: 1.4rem;
      font-weight: 800;
      color: #2d2d2d;
      letter-spacing: -0.3px;
    }
    .gmeow-footer-brand-name span { color: #c87941; }
    .gmeow-footer-desc {
      font-size: 0.9rem;
      color: #a89888;
      line-height: 1.6;
      max-width: 280px;
    }
    .gmeow-footer h6 {
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #c87941;
      margin-bottom: 0.75rem;
    }
    .gmeow-subscribe-wrap { display: flex; }
    .gmeow-subscribe-input {
      background: #3d3530;
      border: 1px solid #4a3e32;
      border-right: none;
      color: #f0e6d8;
      border-radius: 8px 0 0 8px;
      padding: 8px 12px;
      font-size: 0.85rem;
      flex: 1;
      outline: none;
      transition: border-color 0.15s;
    }
    .gmeow-subscribe-input::placeholder { color:  #fff; }
    .gmeow-subscribe-input:focus { border-color: #c87941; }
    .gmeow-subscribe-btn {
      background: #c87941;
      border: none;
      color: #fff;
      border-radius: 0 8px 8px 0;
      padding: 8px 16px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s;
    }
    .gmeow-subscribe-btn:hover { background: #a8622e; }
    .gmeow-footer-divider { border-color: #3d3530; margin: 2rem 0 1rem; }
    .gmeow-footer-bottom { font-size: 0.78rem; color: #6a5a4a; }
    .footer-author-link { text-decoration: none; }
    .footer-author {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 1rem;
      padding: 8px 12px;
      border: 1px solid #3d3530;
      border-radius: 10px;
      transition: border-color 0.15s, background 0.15s;
    }
    .footer-author:hover { border-color: #c87941; background: #3a3028; }
    .footer-author-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #c87941;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.9rem;
      flex-shrink: 0;
    }
    .footer-author-name { font-size: 0.88rem; font-weight: 600; color: #c87941; }
    .footer-author-sub { font-size: 0.75rem; color: #c87941; }
    .gmeow-footer-bottom a { color: #8a7a6a; text-decoration: none; }
    .gmeow-footer-bottom a:hover { color: #c87941; }
  </style>

  <nav class="gmeow-nav">
    <div class="container">
      <a class="gmeow-brand" href="/">
        <img src="/images/logo.png" alt="Gmeow" onerror="this.style.display='none'">
        <span class="gmeow-brand-text">G<span>meow</span></span>
      </a>
      <div class="gmeow-nav-right">
        <ul class="gmeow-links">
          <li><a href="/">Trang chủ</a></li>
        </ul>
        <a href="/reading-list" class="gmeow-rl-btn" id="nav-rl-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
            <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>
          </svg>
          Đọc sau
          <span class="gmeow-rl-count" id="nav-rl-count" style="display:none">0</span>
        </a>
        <button id="dark-mode-toggle" class="gmeow-dark-btn" aria-label="Chuyển dark mode">
          <img id="dark-mode-icon" src="/images/idea.png" width="18" height="18" alt="Dark mode">
        </button>
      </div>
    </div>
  </nav>

  <div class="container">
    <!-- Hero Section -->
    <div style="padding: 2.5rem 0 2rem; text-align: center; border-bottom: 1.5px solid #e8d9c5; margin-bottom: 2.5rem;">
      <% if (typeof category !== 'undefined' && category) { %>
        <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #c87941; font-weight: 700; margin-bottom: 0.5rem;">DANH MỤC</div>
        <h1 style="font-size: 2rem; font-weight: 800; color: #2d2d2d; letter-spacing: -0.5px; margin: 0 0 0.5rem 0;"><%= category %></h1>
        <p style="font-size: 0.95rem; color: #9a8a7a; margin: 0;">Khám phá các bài viết về <%= category.toLowerCase() %></p>
      <% } else { %>
        <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #c87941; font-weight: 700; margin-bottom: 0.5rem;">CHÀO MỪNG ĐẾN GMEOW</div>
        <h1 style="font-size: 2rem; font-weight: 800; color: #2d2d2d; letter-spacing: -0.5px; margin: 0 0 0.5rem 0;">Bài viết mới nhất</h1>
        <p style="font-size: 0.95rem; color: #9a8a7a; margin: 0;">Một góc nhỏ để viết, để nghĩ, và để nhớ.</p>
      <% } %>
    </div>
    
    <!-- Category Pills -->
    <% if (categories && categories.length > 0) { %>
    <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 2.5rem; justify-content: center;">
      <a href="/" style="display: inline-flex; align-items: center; justify-content: center; padding: 6px 18px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1.5px solid #d4b896; background: transparent; color: #2d2d2d; transition: all 0.15s; <%= typeof category === 'undefined' || !category ? 'background: #c87941; border-color: #c87941; color: #fff;' : '' %>" onmouseover="this.style.background='#ead6bc'; this.style.borderColor='#c87941'; this.style.color='#2d2d2d';" onmouseout="this.style.background='<%= typeof category === 'undefined' || !category ? '#c87941' : 'transparent' %>'; this.style.borderColor='<%= typeof category === 'undefined' || !category ? '#c87941' : '#d4b896' %>'; this.style.color='<%= typeof category === 'undefined' || !category ? '#fff' : '#2d2d2d' %>';">
        Tất cả
      </a>
      <% categories.forEach(cat => { %>
        <a href="/category/<%= encodeURIComponent(cat) %>" style="display: inline-flex; align-items: center; justify-content: center; padding: 6px 18px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; text-decoration: none; border: 1.5px solid #d4b896; background: transparent; color: #2d2d2d; transition: all 0.15s; <%= category === cat ? 'background: #c87941; border-color: #c87941; color: #fff;' : '' %>" onmouseover="this.style.background='#ead6bc'; this.style.borderColor='#c87941'; this.style.color='#2d2d2d';" onmouseout="this.style.background='<%= category === cat ? '#c87941' : 'transparent' %>'; this.style.borderColor='<%= category === cat ? '#c87941' : '#d4b896' %>'; this.style.color='<%= category === cat ? '#fff' : '#2d2d2d' %>';">
          <%= cat %>
        </a>
      <% }) %>
    </div>
    <% } %>
    
    <!-- Search Section -->
    <div style="margin-bottom: 3rem;">
      <div class="row">
        <div class="col-lg-10 mx-auto">
          <form action="/search" method="GET" id="search-form">
            <div style="display: flex; gap: 10px; position: relative;">
              <input type="text" id="search-input" name="q" class="form-control" placeholder="Tìm kiếm bài viết..." autocomplete="off" style="font-size: 0.95rem; padding: 10px 14px;">
              <select name="category" class="form-select" style="max-width: 180px; font-size: 0.95rem;">
                <option value="">Tất cả danh mục</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat %>"><%= cat %></option>
                <% }) %>
              </select>
              <button class="btn btn-primary" type="submit" style="font-weight: 600; padding: 10px 24px;">Tìm</button>
            </div>
            <!-- Dropdown kết quả gợi ý -->
            <div id="search-results" class="list-group position-absolute w-100 shadow" style="display:none; z-index:1000; max-height:300px; overflow-y:auto; margin-top: 4px;"></div>
          </form>
        </div>
      </div>
    </div>

    <!-- Masonry CSS -->
    <style>
      .masonry {
        display: block;
        margin: -1rem;
        margin-bottom: 2rem;
      }
      .masonry-item {
        float: left;
        width: calc(50% - 2rem);
        margin: 1rem;
      }
      .masonry-item .card {
        border: 1px solid #e8d9c5;
        border-radius: 12px;
        overflow: hidden;
        transition: box-shadow 0.2s, transform 0.2s;
        display: flex;
        flex-direction: column;
        background: #fff;
      }
      .masonry-item .card:hover {
        box-shadow: 0 8px 24px rgba(200, 121, 65, 0.12);
        transform: translateY(-3px);
      }
      .masonry-item .card > img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
      }
      .masonry-item .card-body {
        padding: 1.2rem;
        display: flex;
        flex-direction: column;
        flex: 1;
      }
      .masonry-item .card-title {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.4;
        margin-bottom: 0.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .masonry-item .card-title a {
        color: #2d2d2d;
        text-decoration: none;
      }
      .masonry-item .card-title a:hover {
        color: #c87941;
      }
      .masonry-item .card-meta {
        font-size: 0.75rem;
        color: #b0a090;
        margin-bottom: 0.75rem;
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
      }
      .masonry-item .card-meta img {
        opacity: 0.6;
      }
      .masonry-item .card-text {
        font-size: 0.84rem;
        color: #6c757d;
        line-height: 1.55;
        flex: 1;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .masonry-item .card-category {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #c87941;
        margin-bottom: 6px;
      }
      .masonry-item .card-footer {
        display: flex;
        gap: 8px;
        align-items: center;
        margin-top: auto;
      }
      @media (max-width: 768px) {
        .masonry-item {
          width: calc(100% - 2rem);
        }
      }
      .masonry::after {
        content: "";
        display: table;
        clear: both;
      }
      /* Bookmark button */
      .card-bookmark-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;
        border: 1.5px solid #d4b896; background: transparent; color: #888; cursor: pointer;
        transition: all 0.2s; margin-left: auto;
      }
      .card-bookmark-btn:hover { border-color: #c87941; color: #c87941; background: #fdf3e8; }
      .card-bookmark-btn.bookmarked { background: #c87941; border-color: #c87941; color: #fff; }
      .card-bookmark-btn.bookmarked:hover { background: #a8622e; border-color: #a8622e; }

      /* Search dropdown */
      #search-results { border-radius: 10px; overflow: hidden; border: 1px solid #e2e8f0; }
      #search-results .list-group-item {
        border-left: none; border-right: none;
        padding: 10px 14px;
        transition: background 0.12s;
      }
      #search-results .list-group-item:first-child { border-top: none; }
      #search-results .list-group-item:last-child { border-bottom: none; }
      #search-results .list-group-item:hover,
      #search-results .list-group-item.active {
        background: #fdf3e8 !important;
        color: inherit !important;
        border-color: #e2e8f0 !important;
      }
      #search-results .list-group-item.active { border-left: 3px solid #c87941 !important; }

      /* Dark mode */
      [data-bs-theme="dark"] .masonry-item .card { border-color: #3a3028; background: #1a1612; }
      [data-bs-theme="dark"] .masonry-item .card-title a { color: #f0e6d8; }
      [data-bs-theme="dark"] .masonry-item .card-text { color: #8a7a6a; }
      [data-bs-theme="dark"] #search-results { border-color: #334155; }
      [data-bs-theme="dark"] #search-results .list-group-item:hover,
      [data-bs-theme="dark"] #search-results .list-group-item.active {
        background: #1e293b !important;
        color: #e2e8f0 !important;
      }
    </style>

    <!-- Container grid -->
    <div id="posts-container" class="masonry">
      <% if (posts && posts.length > 0) { %>
        <% posts.forEach(post => { %>
          <div class="masonry-item post-item">
            <div class="card">
              <% if (post.thumbnail) { %>
                <img src="<%= post.thumbnail %>" alt="<%= post.title %>">
              <% } else { %>
                <div style="width: 100%; height: 180px; background: #f5ede0; display: flex; align-items: center; justify-content: center; font-size: 2rem; color: #d4b896;">✦</div>
              <% } %>
              <div class="card-body">
                <div class="card-category"><%= post.category %></div>
                <h3 class="card-title">
                  <a href="/post/<%= post._id %>">
                    <%= post.title %>
                  </a>
                </h3>
                <div class="card-meta">
                  <span><%= post.createdAt.toLocaleDateString('vi-VN') %></span>
                  <span>·</span>
                  <img src="/images/hourglass.png" width="12" height="12" alt="" style="vertical-align:middle;"> <span><%= post.readingTime || 1 %> phút</span>
                </div>
                <p class="card-text"><%=
                  (post.excerpt || post.content)
                    .replace(/<[^>]+>/g, ' ')
                    .replace(/\s+/g, ' ')
                    .trim()
                    .substring(0, 160) + '...'
                %></p>
                <div class="card-footer">
                  <a href="/post/<%= post._id %>" style="display: inline-flex; align-items: center; justify-content: center; padding: 6px 14px; border-radius: 6px; background: #c87941; color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: background 0.15s;" onmouseover="this.style.background='#a8622e';" onmouseout="this.style.background='#c87941';">Đọc thêm</a>
                  <button class="card-bookmark-btn"
                    onclick="toggleCardBookmark(this)"
                    data-id="<%= post._id %>"
                    data-title="<%= post.title.replace(/"/g, '&quot;') %>"
                    data-excerpt="<%= (post.excerpt || '').substring(0, 120).replace(/"/g, '&quot;') %>"
                    data-category="<%= post.category %>"
                    data-reading-time="<%= post.readingTime || 1 %>"
                    data-thumbnail="<%= post.thumbnail || '' %>"
                    data-url="/post/<%= post._id %>"
                    title="Lưu đọc sau">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                      <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p style="grid-column: 1 / -1; text-align: center; color: #9a8a7a;">Chưa có bài viết nào.</p>
      <% } %>
    </div>

    <!-- Phân trang -->
    <%- include('partials/pagination') %>
  </div>

  <footer class="gmeow-footer">
    <div class="container">
      <div class="row g-4">
        <!-- Brand -->
        <div class="col-md-4">
          <div class="gmeow-footer-brand">
            <img src="/images/logo.png" alt="Gmeow" onerror="this.style.display='none'">
            <span class="gmeow-footer-brand-name">G<span>meow</span></span>
          </div>
          <p class="gmeow-footer-desc">Một góc nhỏ để viết, để nghĩ, và để nhớ.</p>
          <!-- Author mini card -->
          <% if (typeof siteAuthor !== 'undefined' && siteAuthor) { %>
          <a href="/author/<%= siteAuthor.username %>" class="footer-author-link">
            <div class="footer-author">
