            <div class="gmeow-subscribe-wrap">
              <input type="email" id="subscribe-email" class="gmeow-subscribe-input" placeholder="email-của-bạn@.com" required>
              <button type="submit" id="subscribe-btn" class="gmeow-subscribe-btn">Đăng ký</button>
            </div>
            <div id="subscribe-message" class="mt-2" style="font-size:0.8rem;"></div>
