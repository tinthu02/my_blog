                <img src="<%= siteAuthor.avatar %>" class="footer-author-avatar" style="object-fit:cover;padding:0;" alt="">
              <% } else { %>
                <div class="footer-author-avatar">
                  <%= (siteAuthor.displayName || siteAuthor.username).charAt(0).toUpperCase() %>
                </div>
              <% } %>
              <div>
                <div class="footer-author-name"><%= siteAuthor.displayName || siteAuthor.username %></div>
                <div class="footer-author-sub">Xem trang tác giả →</div>
