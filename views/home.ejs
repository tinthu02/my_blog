  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() {
      const searchInput = document.getElementById('search-input');
      const searchResults = document.getElementById('search-results');
      let debounceTimer;

      if (!searchInput || !searchResults) return;

      searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        const query = this.value.trim();

        if (query.length < 2) {
          searchResults.style.display = 'none';
          return;
        }

        debounceTimer = setTimeout(async () => {
          try {
            const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
            const data = await response.json();
            if (!data.success) throw new Error('Lỗi');

            renderResults(data.results, query); // Truyền query để highlight
          } catch (err) {
            console.error(err);
            searchResults.style.display = 'none';
          }
        }, 300);
      });

      // Cập nhật hàm renderResults
      function renderResults(posts, query) {
        searchResults.innerHTML = '';
        if (posts.length === 0) {
          searchResults.innerHTML = '<div class="list-group-item">Không tìm thấy bài viết</div>';
          searchResults.style.display = 'block';
          return;
        }

        posts.forEach(post => {
          const item = document.createElement('a');
          item.href = `/post/${post._id}`;
          item.className = 'list-group-item list-group-item-action';
          // Highlight trong tiêu đề và excerpt
          const title = highlightText(post.title, query);
          const excerpt = highlightText(post.excerpt || (post.content ? post.content.substring(0, 100) + '...' : ''), query);
          item.innerHTML = `
            <div class="fw-bold">${title}</div>
            <small class="text-muted">${excerpt}</small>
          `;
          searchResults.appendChild(item);
        });
        searchResults.style.display = 'block';
      }

      // Hàm highlight: wrap từ khóa trong <mark>, giữ nguyên hoa thường
      function highlightText(text, query) {
        if (!query || !text) return escapeHtml(text);
        const escapedText = escapeHtml(text);
        const escapedQuery = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); // escape regex
        const regex = new RegExp(`(${escapedQuery})`, 'gi');
        return escapedText.replace(regex, '<mark>$1</mark>');
      }

      // Ẩn dropdown khi click ra ngoài
      document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
          searchResults.style.display = 'none';
        }
      });

      // Khi focus lại vào input, nếu đã có kết quả thì hiển thị lại
      searchInput.addEventListener('focus', function() {
        if (this.value.trim().length >= 2 && searchResults.children.length > 0) {
          searchResults.style.display = 'block';
        }
      });

      // Điều hướng bằng phím Up/Down/Enter/Escape
      let activeIndex = -1;

      function getItems() {
        return Array.from(searchResults.querySelectorAll('a.list-group-item'));
      }

      function setActive(index) {
        const items = getItems();
        items.forEach(item => item.classList.remove('active'));
        if (index >= 0 && index < items.length) {
          items[index].classList.add('active');
          items[index].scrollIntoView({ block: 'nearest' });
        }
        activeIndex = index;
      }

      searchInput.addEventListener('keydown', function(e) {
        const items = getItems();
        if (!items.length || searchResults.style.display === 'none') return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(activeIndex < items.length - 1 ? activeIndex + 1 : 0);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(activeIndex > 0 ? activeIndex - 1 : items.length - 1);
        } else if (e.key === 'Enter' && activeIndex >= 0) {
          e.preventDefault();
          items[activeIndex].click();
        } else if (e.key === 'Escape') {
          searchResults.style.display = 'none';
          activeIndex = -1;
        }
      });

      // Reset activeIndex khi gõ mới
      searchInput.addEventListener('input', () => { activeIndex = -1; });

      function escapeHtml(text) {
        const map = {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#039;'
        };
        return String(text).replace(/[&<>"']/g, m => map[m]);
      }
    })();
  </script>
  <script>
    (function() {
      const subscribeForm = document.getElementById('subscribe-form');
      const emailInput = document.getElementById('subscribe-email');
      const subscribeBtn = document.getElementById('subscribe-btn');
      const messageDiv = document.getElementById('subscribe-message');

      if (!subscribeForm || !emailInput || !subscribeBtn || !messageDiv) return;

      subscribeForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        const email = emailInput.value.trim();
        messageDiv.innerHTML = '';

        if (!email) {
          showMessage('Vui lòng nhập email', 'text-warning');
          return;
        }

        subscribeBtn.disabled = true;
        subscribeBtn.textContent = 'Đang gửi...';

        try {
          const response = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
          });
          const data = await response.json();
          if (!response.ok || !data.success) throw new Error(data.message);
          showMessage(data.message, 'text-success');
          emailInput.value = '';
        } catch (error) {
          showMessage(error.message, 'text-danger');
        } finally {
          subscribeBtn.disabled = false;
          subscribeBtn.textContent = 'Đăng ký';
        }
      });

      function showMessage(msg, className) {
        messageDiv.innerHTML = `<span class="${className}">${escapeHtml(msg)}</span>`;
        setTimeout(() => { if (messageDiv) messageDiv.innerHTML = ''; }, 5000);
      }

      function escapeHtml(text) {
        const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
        return String(text).replace(/[&<>"']/g, m => map[m]);
      }
    })();
  </script>
  <%- include('partials/back-to-top') %>
  <script src="/js/dark-mode.js"></script>
  <script>
    function getBookmarks() {
      try { return JSON.parse(localStorage.getItem('gmeow_bookmarks') || '[]'); }
      catch { return []; }
    }

    function updateNavBadge() {
      var count = getBookmarks().length;
      var badge = document.getElementById('nav-rl-count');
      if (!badge) return;
      if (count > 0) {
        badge.style.display = 'inline-flex';
        badge.textContent = count > 9 ? '9+' : count;
      } else {
        badge.style.display = 'none';
      }
    }

    function toggleCardBookmark(btn) {
      var id = btn.dataset.id;
      var bookmarks = getBookmarks();
      var isBookmarked = bookmarks.some(function(b) { return b.id === id; });

      if (isBookmarked) {
        bookmarks = bookmarks.filter(function(b) { return b.id !== id; });
      } else {
        bookmarks.unshift({
          id: id,
          title: btn.dataset.title,
          excerpt: btn.dataset.excerpt,
          category: btn.dataset.category,
          readingTime: parseInt(btn.dataset.readingTime) || 1,
          thumbnail: btn.dataset.thumbnail,
          url: btn.dataset.url,
          savedAt: new Date().toISOString()
        });
      }
      localStorage.setItem('gmeow_bookmarks', JSON.stringify(bookmarks));
      updateCardBookmarkUI(btn, !isBookmarked);
      updateNavBadge();
    }

    function updateCardBookmarkUI(btn, bookmarked) {
      var span = btn.querySelector('span');
      var svg = btn.querySelector('svg');
      if (bookmarked) {
        btn.classList.add('bookmarked');
        if (span) span.textContent = 'Đã lưu';
        if (svg) svg.innerHTML = '<path d="M2 2v13.5a.5.5 0 0 0 .777.416L8 13.101l5.223 2.815A.5.5 0 0 0 14 15.5V2a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>';
      } else {
        btn.classList.remove('bookmarked');
        if (span) span.textContent = 'Đọc sau';
        if (svg) svg.innerHTML = '<path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>';
      }
    }

    // Khởi tạo trạng thái bookmark cho tất cả card khi load trang
    document.addEventListener('DOMContentLoaded', function() {
      var bookmarks = getBookmarks();
      var ids = bookmarks.map(function(b) { return b.id; });
      document.querySelectorAll('.card-bookmark-btn').forEach(function(btn) {
        if (ids.includes(btn.dataset.id)) {
          updateCardBookmarkUI(btn, true);
        }
      });
      updateNavBadge();
    });
  </script>
